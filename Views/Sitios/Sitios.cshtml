@{
    ViewData["Title"] = "Mantenimiento de Sitios";
}

<div class="page-header">
    <h3 class="fw-bold mb-3">Administración de Sitios</h3>
    <ul class="breadcrumbs mb-3">
        <li class="nav-home">
            <a href="/Home/Index"><i class="fas fa-home"></i></a>
        </li>
        <li class="separator"><i class="fas fa-arrow-right"></i></li>
        <li class="nav-item"><a>Mantenimientos</a></li>
        <li class="separator"><i class="fas fa-arrow-right"></i></li>
        <li class="nav-item"><a>Sitios</a></li>
    </ul>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between bg-white py-3">
                <div class="card-title text-secondary fw-semibold m-0">
                    <i class="fas fa-parking me-2 text-primary"></i> Lista de Sitios Estacionamiento
                </div>
                <button class="btn btn-primary btn-round ms-auto" id="btnAbrirModalSitio">
                    <i class="fa fa-plus me-2"></i> Nuevo Sitio
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="tablaSitios" class="display table table-striped table-hover w-100">
                        <thead class="bg-dark text-white text-center">
                            <tr>
                                <th style="width: 10%">ID</th>
                                <th>Nombre del Sitio / Casillero</th>
                                <th>Sede de Estacionamiento</th>
                                <th style="width: 15%">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="text-center align-middle">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalSitio" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
            <div class="modal-header bg-primary text-white py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                <h4 class="modal-title fw-bold mb-0" id="modalTitulo"><i class="fas fa-plus-circle me-2"></i> Registrar Sitios</h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formModalSitio" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">

                    <input type="hidden" id="SitiId" name="SitiId" />

                    <div class="form-group mb-3 px-0">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Sede Estacionamiento <span class="text-danger">*</span></label>
                        <select class="form-select" id="SedeEstacionamientosFk" name="SedeEstacionamientosFk" style="font-size: 1.05rem;" required>
                            <option value="" disabled selected>-- Seleccione una opción --</option>
                        </select>
                    </div>

                    <div class="form-group mb-3 px-0" id="divCantidad">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Cantidad de Sitios a Generar <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="CantidadSitios" name="CantidadSitios" min="1" max="100" placeholder="Ej: 15" style="font-size: 1.05rem;" required />
                    </div>

                    <div class="form-group mb-3 px-0" id="divNombreIndividual" style="display: none;">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Nombre del Sitio / Casillero <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="SitiNombreSitio" name="SitiNombreSitio" placeholder="Ej: Sitio Modificado" style="font-size: 1.05rem;" />
                    </div>

                </div>
                <div class="modal-footer bg-light p-3" style="border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
                    <button type="button" class="btn btn-secondary px-3" style="font-size: 0.95rem;" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" id="btnGuardarSitio" class="btn btn-primary px-4 fw-bold" style="font-size: 0.95rem;">
                        <i class="fas fa-save me-1"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/plugin/datatables/datatables.min.js"></script>

    <script>
        $(document).ready(function () {

            // Inicializamos la data al cargar la página
            cargarSedesCombo();
            initDataTable();

            // Al abrir para un Nuevo Registro (Generación Masiva)
            $('#btnAbrirModalSitio').click(function() {
                $('#formModalSitio')[0].reset();
                $('#SitiId').val('0');
                $('#modalTitulo').html('<i class="fas fa-plus-circle me-2"></i> Generar Sitios Automáticos');

                // Mostrar campo numérico y ocultar el de texto individual
                $('#divCantidad').show();
                $('#CantidadSitios').prop('required', true);
                $('#divNombreIndividual').hide();
                $('#SitiNombreSitio').prop('required', false);

                $('#modalSitio').modal('show');
            });

            // Al presionar Editar dentro de la DataTable (Edición Individual)
            $('#tablaSitios').on('click', '.btn-editar-sitio', function() {
                $('#modalTitulo').html('<i class="fas fa-edit me-2"></i> Modificar Datos de Sitio');

                $('#SitiId').val($(this).data('id'));
                $('#SedeEstacionamientosFk').val($(this).data('sede'));
                $('#SitiNombreSitio').val($(this).data('nombre'));

                // Ocultar generador masivo y mostrar campo de texto individual obligatorio
                $('#divCantidad').hide();
                $('#CantidadSitios').prop('required', false);
                $('#divNombreIndividual').show();
                $('#SitiNombreSitio').prop('required', true);

                $('#modalSitio').modal('show');
            });

            // Función: Carga el selector de Sedes dinámicamente desde tu controlador de Sedes
            function cargarSedesCombo() {
                $.getJSON('/Sedes/ObtenerSedesJson', function (data) {
                    const select = $('#SedeEstacionamientosFk');
                    select.html('<option value="" disabled selected>-- Seleccione una opción --</option>');

                    data.forEach(sede => {
                        select.append(`<option value="${sede.seestId}">${sede.seestNombreEstacionamiento}</option>`);
                    });
                });
            }

            function initDataTable() {
                $('#tablaSitios').DataTable({
                    ajax: {
                        url: '/Sitios/ObtenerSitiosJson',
                        dataSrc: ''
                    },
                    destroy: true,
                    responsive: true,
                    columns: [
                        { data: 'sitiId' },
                        { data: 'sitiNombreSitio', className: 'text-start align-middle' },
                        { data: 'sedeNombre', className: 'text-start align-middle' },
                        {
                            data: null,
                            orderable: false,
                            render: function(data, type, row) {
                                return `
                                    <div class="form-button-action justify-content-center">
                                        <button type="button" class="btn btn-link btn-primary btn-lg btn-editar-sitio"
                                                data-id="${row.sitiId}" data-sede="${row.sedeEstacionamientosFk}"
                                                data-nombre="${row.sitiNombreSitio}" data-bs-toggle="tooltip" title="Editar">
                                            <i class="fa fa-edit fs-5"></i>
                                        </button>
                                        <button type="button" class="btn btn-link btn-danger btn-lg btn-anular-sitio"
                                                data-id="${row.sitiId}" data-bs-toggle="tooltip" title="Anular">
                                            <i class="fa fa-times fs-4"></i>
                                        </button>
                                    </div>
                                `;
                            }
                        }
                    ],
                    language: {
                        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                    }
                });
            }

            // PROCESAR GUARDAR (CREAR MASIVO O ACTUALIZAR INDIVIDUAL)
            $('#formModalSitio').submit(function (e) {
                e.preventDefault();

                const btn = $('#btnGuardarSitio');
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span> Guardando...');

                $.ajax({
                    url: '/Sitios/RegistrarSitio',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: (res) => {
                        if (res.success) {
                            $('#modalSitio').modal('hide');

                            Swal.fire({
                                icon: 'success',
                                title: '¡Operación Exitosa!',
                                text: res.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                // Recarga asíncrona en caliente manteniendo la paginación
                                $('#tablaSitios').DataTable().ajax.reload(null, false);
                            });
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'Atención',
                                text: res.message
                            });
                        }
                        restaurarBotonGuardar(btn);
                    },
                    error: () => {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Ocurrió un error en el servidor al procesar la solicitud.'
                        });
                        restaurarBotonGuardar(btn);
                    }
                });
            });

            // PROCESAR ANULACIÓN LÓGICA
            $('#tablaSitios').on('click', '.btn-anular-sitio', function() {
                const idSitio = $(this).data('id');

                Swal.fire({
                    title: '¿Está seguro de anular el sitio?',
                    text: "Esta acción inhabilitará temporalmente el espacio de parqueo.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-trash-alt me-1"></i> Sí, anular',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Sitios/AnularSitio',
                            type: 'POST',
                            data: { id: idSitio },
                            success: (res) => {
                                if (res.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Sitio Anulado',
                                        text: res.message,
                                        timer: 1500,
                                        showConfirmButton: false
                                    }).then(() => {
                                        // Recarga asíncrona de las filas
                                        $('#tablaSitios').DataTable().ajax.reload(null, false);
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Error',
                                        text: res.message
                                    });
                                }
                            },
                            error: () => {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Fallo de Red',
                                    text: 'No se pudo completar la solicitud de anulación.'
                                });
                            }
                        });
                    }
                });
            });

            function restaurarBotonGuardar(boton) {
                boton.prop('disabled', false).html('<i class="fas fa-save me-1"></i> Guardar Cambios');
            }
        });
    </script>
}