@{
    ViewData["Title"] = "Mantenimiento de Sedes";
}

<div class="page-header">
    <h3 class="fw-bold mb-3">Administración de Sedes</h3>
    <ul class="breadcrumbs mb-3">
        <li class="nav-home">
            <a href="/Home/Index"><i class="fas fa-home"></i></a>
        </li>
        <li class="separator"><i class="fas fa-arrow-right"></i></li>
        <li class="nav-item"><a>Mantenimientos</a></li>
        <li class="separator"><i class="fas fa-arrow-right"></i></li>
        <li class="nav-item"><a>Sedes</a></li>
    </ul>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between bg-white py-3">
                <div class="card-title text-secondary fw-semibold m-0">
                    <i class="fas fa-warehouse me-2 text-primary"></i> Lista de Sedes Registradas
                </div>
                <button class="btn btn-primary btn-round ms-auto" id="btnAbrirModalSede">
                    <i class="fa fa-plus me-2"></i> Nueva Sede
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="tablaSedes" class="display table table-striped table-hover w-100">
                        <thead class="bg-dark text-white text-center">
                            <tr>
                                <th style="width: 10%">ID</th>
                                <th>Nombre de la Sede</th>
                                <th>Ubicación / Dirección</th>
                                <th style="width: 15%">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="text-center align-middle">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalSede" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
            <div class="modal-header bg-primary text-white py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                <h4 class="modal-title fw-bold mb-0" id="modalTitulo"><i class="fas fa-plus-circle me-2"></i> Registrar Sede</h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formModalSede" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">

                    <input type="hidden" id="SeestId" name="SeestId" />

                    <div class="form-group mb-3 px-0">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Nombre de Sede <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="SeestNombreEstacionamiento" name="SeestNombreEstacionamiento" placeholder="Ej: Sede Central Chala" style="font-size: 1.05rem;" required />
                    </div>

                    <div class="form-group mb-3 px-0">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Ubicación / Dirección <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="SeestUbicacion" name="SeestUbicacion" placeholder="Ej: Av. Principal Nro. 123" style="font-size: 1.05rem;" required />
                    </div>

                </div>
                <div class="modal-footer bg-light p-3" style="border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
                    <button type="button" class="btn btn-secondary px-3" style="font-size: 0.95rem;" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" id="btnGuardarSede" class="btn btn-primary px-4 fw-bold" style="font-size: 0.95rem;">
                        <i class="fas fa-save me-1"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/plugin/datatables/datatables.min.js"></script>

    <script>
        $(document).ready(function () {

            initDataTable();

            $('#btnAbrirModalSede').click(function() {
                $('#formModalSede')[0].reset();
                $('#SeestId').val('0');
                $('#modalTitulo').html('<i class="fas fa-plus-circle me-2"></i> Registrar Sede');
                $('#modalSede').modal('show');
            });

            function initDataTable() {
                $('#tablaSedes').DataTable({
                    ajax: {
                        url: '/Sedes/ObtenerSedesJson',
                        dataSrc: ''
                    },
                    destroy: true,
                    responsive: true,
                    columns: [
                        { data: 'seestId' },
                        { data: 'seestNombreEstacionamiento', className: 'text-start align-middle' },
                        { data: 'seestUbicacion', className: 'text-start align-middle' },
                        {
                            data: null,
                            orderable: false,
                            render: function(data, type, row) {
                                return `
                                    <div class="form-button-action justify-content-center">
                                        <button type="button" class="btn btn-link btn-primary btn-lg btn-editar-sede"
                                                data-id="${row.seestId}" data-nombre="${row.seestNombreEstacionamiento}"
                                                data-ubicacion="${row.seestUbicacion}">
                                            <i class="fa fa-edit fs-5"></i>
                                        </button>
                                        <button type="button" class="btn btn-link btn-danger btn-lg btn-anular-sede"
                                                data-id="${row.seestId}">
                                            <i class="fa fa-times fs-4"></i>
                                        </button>
                                    </div>
                                `;
                            }
                        }
                    ],
                    language: {
                        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                    }
                });
            }

            // GUARDAR / ACTUALIZAR CON RECARGA ASÍNCRONA
            $('#formModalSede').submit(function (e) {
                e.preventDefault();

                const btn = $('#btnGuardarSede');
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span> Guardando...');

                $.ajax({
                    url: '/Sedes/RegistrarSede',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: (res) => {
                        if (res.success) {
                            $('#modalSede').modal('hide');

                            Swal.fire({
                                icon: 'success',
                                title: '¡Operación Exitosa!',
                                text: res.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                // RECARGA LA TABLA EN CALIENTE MANTENIENDO LA PAGINACIÓN
                                $('#tablaSedes').DataTable().ajax.reload(null, false);
                            });
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'Atención',
                                text: res.message
                            });
                        }
                        restaurarBotonGuardar(btn);
                    },
                    error: () => {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Ocurrió un error en el servidor al intentar procesar la solicitud.'
                        });
                        restaurarBotonGuardar(btn);
                    }
                });
            });

            // ENVIAR DATOS DE LA FILA AL MODAL PARA EDITAR
            $('#tablaSedes').on('click', '.btn-editar-sede', function() {
                $('#modalTitulo').html('<i class="fas fa-edit me-2"></i> Modificar Datos de Sede');

                $('#SeestId').val($(this).data('id'));
                $('#SeestNombreEstacionamiento').val($(this).data('nombre'));
                $('#SeestUbicacion').val($(this).data('ubicacion'));

                $('#modalSede').modal('show');
            });

            // ANULAR CON CONFIRMACIÓN Y RECARGA EN CALIENTE
            $('#tablaSedes').on('click', '.btn-anular-sede', function() {
                const idSede = $(this).data('id');

                Swal.fire({
                    title: '¿Está seguro de anular la sede?',
                    text: "Esta acción deshabilitará la sede seleccionada de forma lógica.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fas fa-trash-alt me-1"></i> Sí, anular',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Sedes/AnularSede',
                            type: 'POST',
                            data: { id: idSede },
                            success: (res) => {
                                if (res.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Sede Anulada',
                                        text: res.message,
                                        timer: 1500,
                                        showConfirmButton: false
                                    }).then(() => {
                                        // RECARGA EN CALIENTE AL ANULAR
                                        $('#tablaSedes').DataTable().ajax.reload(null, false);
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Error',
                                        text: res.message
                                    });
                                }
                            },
                            error: () => {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Fallo de Red',
                                    text: 'No se pudo comunicar la petición con el servidor.'
                                });
                            }
                        });
                    }
                });
            });

            function restaurarBotonGuardar(boton) {
                boton.prop('disabled', false).html('<i class="fas fa-save me-1"></i> Guardar Cambios');
            }
        });
    </script>
}