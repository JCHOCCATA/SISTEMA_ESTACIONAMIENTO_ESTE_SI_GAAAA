@{
    ViewData["Title"] = "Mantenimiento de Entidades";
}

<div class="page-header">
    <h3 class="fw-bold mb-3">Administración de Entidades</h3>
    <ul class="breadcrumbs mb-3">
        <li class="nav-home">
            <a href="/Home/Index"><i class="fas fa-home"></i></a>
        </li>
        <li class="separator"><i class="fas fa-arrow-right"></i></li>
        <li class="nav-item"><a>Mantenimientos</a></li>
        <li class="separator"><i class="fas fa-arrow-right"></i></li>
        <li class="nav-item"><a>Entidades</a></li>
    </ul>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center justify-content-between bg-white py-3">
                <div class="card-title text-secondary fw-semibold m-0">
                    <i class="fas fa-address-book me-2 text-primary"></i> Lista de Entidades Registradas
                </div>
                <button class="btn btn-primary btn-round ms-auto" id="btnAbrirModalEntidad">
                    <i class="fa fa-plus me-2"></i> Nueva Entidad
                </button>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="tablaEntidades" class="display table table-striped table-hover w-100">
                        <thead class="bg-dark text-white text-center">
                            <tr>
                                <th style="width: 8%">ID</th>
                                <th>Razón Social / Nombre</th>
                                <th style="width: 20%">Tipo Doc.</th>
                                <th style="width: 18%">Nro. Documento</th>
                                <th style="width: 15%">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="text-center align-middle">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEntidad" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
            <div class="modal-header bg-primary text-white py-3" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                <h4 class="modal-title fw-bold mb-0" id="modalTitulo"><i class="fas fa-plus-circle me-2"></i> Registrar Entidad</h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formModalEntidad" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">

                    <input type="hidden" id="EntiId" name="EntiId" />

                    <div class="form-group mb-3 px-0">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Tipo de Documento <span class="text-danger">*</span></label>
                        <select class="form-select" id="TipoDocumentoFk" name="TipoDocumentoFk" style="font-size: 1.05rem;" required>
                            <option value="" disabled selected>-- Seleccione una opción --</option>
                        </select>
                    </div>

                    <div class="form-group mb-3 px-0">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Número de Documento <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="EntiNroDocumento" name="EntiNroDocumento" placeholder="Ingrese el número" maxlength="20" style="font-size: 1.05rem;" required />
                    </div>

                    <div class="form-group mb-3 px-0">
                        <label class="form-label fw-bold text-secondary fs-6" style="font-size: 0.95rem !important;">Razón Social / Nombre Completo <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="EntiRazonSocial" name="EntiRazonSocial" placeholder="Ej: Grupo Empresarial S.A.C." style="font-size: 1.05rem;" required />
                    </div>

                </div>
                <div class="modal-footer bg-light p-3" style="border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
                    <button type="button" class="btn btn-secondary px-3" style="font-size: 0.95rem;" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" id="btnGuardarEntidad" class="btn btn-primary px-4 fw-bold" style="font-size: 0.95rem;">
                        <i class="fas fa-save me-1"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/plugin/datatables/datatables.min.js"></script>

    <script>
        $(document).ready(function () {

            // Inicialización de datos
            cargarTiposDocumento();
            initDataTable();

            $('#btnAbrirModalEntidad').click(function() {
                $('#formModalEntidad')[0].reset();
                $('#EntiId').val('0');
                $('#modalTitulo').html('<i class="fas fa-plus-circle me-2"></i> Registrar Entidad');
                $('#modalEntidad').modal('show');
            });

            // Función para poblar el select dinámicamente desde tu controlador
            function cargarTiposDocumento() {
                $.getJSON('/TipoDocumento/ObtenerTiposDocumentoJson', function (data) {
                    const select = $('#TipoDocumentoFk');
                    // Mantenemos la opción por defecto limpia
                    select.html('<option value="" disabled selected>-- Seleccione una opción --</option>');

                    data.forEach(tipo => {
                        select.append(`<option value="${tipo.tidoId}">${tipo.tidoNombreDoc}</option>`);
                    });
                });
            }

            function initDataTable() {
                $('#tablaEntidades').DataTable({
                    ajax: {
                        url: '/Entidades/ObtenerEntidadesJson',
                        dataSrc: ''
                    },
                    destroy: true,
                    responsive: true,
                    columns: [
                        { data: 'entiId' },
                        { data: 'entiRazonSocial', className: 'text-start align-middle' },
                        { data: 'tipoDocumento' },
                        { data: 'entiNroDocumento' },
                        {
                            data: null,
                            orderable: false,
                            render: function(data, type, row) {
                                return `
                                    <div class="form-button-action justify-content-center">
                                        <button type="button" class="btn btn-link btn-primary btn-lg btn-editar-entidad"
                                                data-id="${row.entiId}" data-doc="${row.tipoDocumentoFk}"
                                                data-nro="${row.entiNroDocumento}" data-rz="${row.entiRazonSocial}"
                                                data-bs-toggle="tooltip" title="Editar">
                                            <i class="fa fa-edit fs-5"></i>
                                        </button>
                                        <button type="button" class="btn btn-link btn-danger btn-lg btn-anular-entidad"
                                                data-id="${row.entiId}" data-bs-toggle="tooltip" title="Anular">
                                            <i class="fa fa-times fs-4"></i>
                                        </button>
                                    </div>
                                `;
                            }
                        }
                    ],
                    language: {
                        url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
                    }
                });
            }

            $('#formModalEntidad').submit(function (e) {
                e.preventDefault();

                const btn = $('#btnGuardarEntidad');
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span> Guardando...');

                $.ajax({
                    url: '/Entidades/RegistrarEntidad',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: (res) => {
                        if (res.success) {
                            $('#modalEntidad').modal('hide');
                            Swal.fire('¡Proceso Exitoso!', res.message, 'success').then(() => {
                                $('#tablaEntidades').DataTable().ajax.reload();
                            });
                        } else {
                            Swal.fire('Atención', res.message, 'warning');
                        }
                        restaurarBotonGuardar(btn);
                    },
                    error: () => {
                        Swal.fire('Error', 'Ocurrió un fallo de red o base de datos al guardar.', 'error');
                        restaurarBotonGuardar(btn);
                    }
                });
            });

            $('#tablaEntidades').on('click', '.btn-editar-entidad', function() {
                $('#modalTitulo').html('<i class="fas fa-edit me-2"></i> Modificar Datos de Entidad');

                $('#EntiId').val($(this).data('id'));
                $('#TipoDocumentoFk').val($(this).data('doc'));
                $('#EntiNroDocumento').val($(this).data('nro'));
                $('#EntiRazonSocial').val($(this).data('rz'));

                $('#modalEntidad').modal('show');
            });

            $('#tablaEntidades').on('click', '.btn-anular-entidad', function() {
                const idEntidad = $(this).data('id');

                Swal.fire({
                    title: '¿Está seguro de anular la entidad?',
                    text: "Esta acción cambiará el estado operacional en el sistema.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, anular',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Entidades/AnularEntidad',
                            type: 'POST',
                            data: { id: idEntidad },
                            success: (res) => {
                                if (res.success) {
                                    Swal.fire('Anulado', res.message, 'success').then(() => {
                                        $('#tablaEntidades').DataTable().ajax.reload();
                                    });
                                } else {
                                    Swal.fire('Error', res.message, 'error');
                                }
                            },
                            error: () => {
                                Swal.fire('Error', 'No se pudo procesar la solicitud de anulación.', 'error');
                            }
                        });
                    }
                });
            });

            function restaurarBotonGuardar(boton) {
                boton.prop('disabled', false).html('<i class="fas fa-save me-1"></i> Guardar Cambios');
            }
        });
    </script>
}